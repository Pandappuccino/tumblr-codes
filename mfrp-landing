            {block:Pagination}
            <div id="pagination" class="mt-1 mb-5">
                <a id="firstpage" href="/" title="First Page"><i class="fa-solid fa-angles-left"></i></a>
                <a id="prevpage" href="{PreviousPage}" title="Previous Page"><i class="fa-solid fa-caret-left"></i></a>
                <span id="pagetotal">{CurrentPage} / {TotalPages}</span>
                <a id="nextpage" href="{NextPage}" title="Next Page"><i class="fa-solid fa-caret-right"></i></a>
                <a id="lastpage" href="/page/{TotalPages}" title="Last Page"><i class="fa-solid fa-angles-right"></i></a>
            </div>
            {/block:Pagination}
        </div>
    </div>

    <script>
        const clock = document.getElementById("time");
        const time = new Date();
        
        function displayClock() {
        	let serverTime = time.toLocaleString("en-US", {
        		timeZone: "America/New_York"
        	});
        	clock.innerHTML = serverTime;
        	console.log = serverTime;
        	time.setTime(Date.now());
        };

        displayClock();
        setInterval(displayClock, 1000);
    </script>
</body>

