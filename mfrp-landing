            </div>
            {/block:PostNotes}
            {/block:Photoset}
            
            {block:Quote}
            <div class="post d-flex flex-row justify-content-start align-items-start">
                <div class="post_body">
                    <div class="post_content">
                        <h2 class="quote">{Quote}</h2>
                        {block:Source}
                        <div class="caption" style="text-align: right;">
                            <i class="fa-solid fa-minus"></i> <i>{Source}</i>
                        </div>
