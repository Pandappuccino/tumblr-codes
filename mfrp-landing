            <div class="notebox p-2 mb-3">
                {PostNotes}
            </div>
            {/block:PostNotes}
            {/block:Panorama}
            
            {block:Photoset}
            <div class="post d-flex flex-row justify-content-start align-items-start">
                <div class="post_body">
                    <div class="post_content">
                        <img src="{Photoset-500}" title="{PhotoAlt}"> {block:Caption}
                        <div class="post_caption">
                            {Caption}
                        </div>
                        {/block:Caption}
                    </div>

